diff --git src/configure.ac src/configure.ac
index 7e113f1..9664682 100644
--- src/configure.ac
+++ src/configure.ac
@@ -99,6 +99,19 @@ system)
   PACKAGE_CFLAGS_PET="$PET_CFLAGS"
 	;;
 esac
+dnl When using bundled pet, link autosa with libclang-cpp for LLVM 18+ (pet's undefined refs)
+CLANG_CPP_LIB=""
+if test "$with_pet" = bundled; then
+	AC_PATH_PROG([LLVM_CONFIG], [llvm-config])
+	if test -n "$LLVM_CONFIG" && test -x "$LLVM_CONFIG"; then
+		CLANG_LIBDIR=`$LLVM_CONFIG --libdir`
+		clang_cpp_path=`ls "$CLANG_LIBDIR"/libclang-cpp.so* 2>/dev/null | head -1`
+		if test -n "$clang_cpp_path" && test -f "$clang_cpp_path"; then
+			CLANG_CPP_LIB="$clang_cpp_path"
+		fi
+	fi
+fi
+AC_SUBST(CLANG_CPP_LIB)
 
